# API Configuration
EXPO_PUBLIC_API_BASE_URL=http://localhost:3001/api/v1
EXPO_PUBLIC_APP_NAME=EDS - Ekosistem Digital Sekolah

# App Config
EXPO_PUBLIC_DEFAULT_SUBDOMAIN=demo
EXPO_PUBLIC_TENANT_BASE_DOMAIN=eds.id

# Feature Flags
EXPO_PUBLIC_ENABLE_BIOMETRIC=true
EXPO_PUBLIC_ENABLE_PUSH_NOTIFICATIONS=true
EXPO_PUBLIC_ENABLE_OFFLINE_MODE=true

# Storage Keys (do not change)
EXPO_PUBLIC_AUTH_TOKEN_KEY=eds_auth_token
EXPO_PUBLIC_REFRESH_TOKEN_KEY=eds_refresh_token
EXPO_PUBLIC_USER_KEY=eds_user_data
EXPO_PUBLIC_SCHOOL_KEY=eds_school_data
