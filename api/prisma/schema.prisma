generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===================== ENUMS =====================

enum Role {
  SUPERADMIN
  ADMIN_YAYASAN
  ADMIN_SEKOLAH
  KEPALA_SEKOLAH
  KEPALA_KURIKULUM
  BENDAHARA
  GURU
  WALI_KELAS
  GURU_BK
  OPERATOR_SIMS
  KASIR_KOPERASI
  PUSTAKAWAN
  PETUGAS_UKS
  TATA_USAHA
  SISWA
  ORANG_TUA
  ALUMNI
  GURU_LES
  MITRA_DU_DI
  PUBLISHER
  DEVELOPER
  EDS_SUPERADMIN
  EDS_SUPPORT
  EDS_SALES
  LISTING_MANAGER
  YAYASAN_ADMIN
  GPK
  SECURITY_OFFICER
  KOMITE_SEKOLAH
  VOLUNTEER
  LISTING_VENDOR
}

enum Gender {
  MALE
  FEMALE
}

enum TenantPlan {
  BASIC
  PRO
  ENTERPRISE
}

enum BloomLevel {
  C1
  C2
  C3
  C4
  C5
  C6
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum QuestionType {
  MULTIPLE_CHOICE
  ESSAY
  TRUE_FALSE
  MATCHING
}

enum ExamStatus {
  DRAFT
  PUBLISHED
  ONGOING
  COMPLETED
}

enum AlertStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  DISMISSED
}

enum NotificationType {
  ATTENDANCE
  PAYMENT
  EXAM
  ANNOUNCEMENT
  ALERT
  HEALTH
  TRANSPORT
  CANTEEN
  LIBRARY
  GENERAL
}

enum NotificationChannel {
  WHATSAPP
  PUSH_NOTIFICATION
  EMAIL
  SMS
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  READ
}

enum InvoiceStatus {
  UNPAID
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  EXPIRED
}

enum LoanStatus {
  BORROWED
  RETURNED
  OVERDUE
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum BookingStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum CounselingStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum BlogPostStatus {
  DRAFT
  REVIEW
  PUBLISHED
  REJECTED
}

enum InternshipStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ScholarshipStatus {
  SUBMITTED
  REVIEWING
  APPROVED
  REJECTED
}

enum PPDBStatus {
  SUBMITTED
  VERIFIED
  ACCEPTED
  REJECTED
  REGISTERED
}

enum EnrollmentStatus {
  ACTIVE
  INACTIVE
  GRADUATED
  TRANSFERRED
}

// ===================== CORE MODELS =====================

model School {
  id         String     @id @default(cuid())
  name       String
  npsn       String     @unique
  subdomain  String     @unique
  address    String
  phone      String?
  email      String?
  logoUrl    String?
  website    String?
  config     Json       @default("{}")
  tenantPlan TenantPlan @default(BASIC)
  isActive   Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  users                User[]
  students             Student[]
  teachers             Teacher[]
  academicYears        AcademicYear[]
  subjects             Subject[]
  schoolClasses        SchoolClass[]
  notifications        Notification[]
  notifTemplates       NotificationTemplate[]
  articles             Article[]
  announcements        Announcement[]
  galleryItems         GalleryItem[]
  ppdbPeriods          PPDBPeriod[]
  exams                Exam[]
  extracurriculars     Extracurricular[]
  forumPosts           ForumPost[]
  meetings             Meeting[]
  invoices             Invoice[]
  rooms                Room[]
  buses                TransportBus[]
  helpdeskTickets      HelpdeskTicket[]
  scholarshipPrograms  ScholarshipProgram[]
  trainingPrograms     TrainingProgram[]
  menuItems            MenuItem[]
  assets               AssetItem[]
  books                LibraryBook[]
  auditLogs            AuditLog[]
  dapodikSyncs         DapodikSync[]
  riskAlerts           RiskAlert[]
  coopProducts         CoopProduct[]
  bullyingReports      BullyingReport[]
  blogPosts            BlogPost[]
  cashlessWallets      CashlessWallet[]
  alumniProfiles       AlumniProfile[]
  portfolios           Portfolio[]
  internships          InternshipPlacement[]
  healthRecords        HealthRecord[]
  uksVisits            UKSVisit[]
  nutritionRecords     NutritionRecord[]
  counselingSessions   CounselingSession[]
  enrollments          Enrollment[]
  studentAttendances   StudentAttendance[]
  teacherAttendances   TeacherAttendance[]
  menuOrders           MenuOrder[]
  roomBookings         RoomBooking[]
  transportLogs        TransportRideLog[]
  libraryLoans         LibraryLoan[]
  scholarshipApps      ScholarshipApplication[]
  trainingEnrollments  TrainingEnrollment[]
  aiInteractions       AIInteraction[]
  plagiarismChecks     PlagiarismCheck[]
  grades               Grade[]
  reportCards          ReportCard[]
  savingsAccounts      SavingsAccount[]
  savingsTransactions  SavingsTransaction[]
  payments             Payment[]
  extraEnrollments     ExtraEnrollment[]
  extraActivities      ExtraActivity[]
  apiKeys              ApiKey[]
}

model User {
  id          String    @id @default(cuid())
  schoolId    String?
  school      School?   @relation(fields: [schoolId], references: [id])
  email       String    @unique
  password    String
  name        String
  role        Role
  phone       String?
  photoUrl    String?
  isActive    Boolean   @default(true)
  lastLoginAt DateTime?
  mfaEnabled  Boolean   @default(false)
  mfaSecret   String?
  mfaMethod   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  apiKeys           ApiKey[]
  organizedMeetings Meeting[]          @relation("MeetingOrganizer")
  meetingParticipations MeetingParticipant[]
  helpdeskReports   HelpdeskTicket[]   @relation("TicketReporter")
  alumniProfile     AlumniProfile?
  forumPosts        ForumPost[]
  forumComments     ForumComment[]
  blogPosts         BlogPost[]
  aiInteractions    AIInteraction[]
  articles          Article[]
}

model AcademicYear {
  id        String   @id @default(cuid())
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id])
  name      String
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean  @default(false)
  createdAt DateTime @default(now())

  semesters    Semester[]
  schoolClasses SchoolClass[]
  enrollments  Enrollment[]
  scholarships ScholarshipProgram[]

  @@unique([schoolId, name])
}

model Semester {
  id             String       @id @default(cuid())
  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  name           String
  startDate      DateTime
  endDate        DateTime
  isCurrent      Boolean      @default(false)

  grades      Grade[]
  reportCards ReportCard[]
  exams       Exam[]
  invoices    Invoice[]

  @@unique([academicYearId, name])
}

model Subject {
  id          String   @id @default(cuid())
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id])
  name        String
  code        String
  gradeLevel  String
  curriculum  String   @default("MERDEKA")
  weeklyHours Int      @default(2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  grades           Grade[]
  plagiarismChecks PlagiarismCheck[]

  @@unique([code, schoolId])
}

model Teacher {
  id       String   @id @default(cuid())
  schoolId String
  school   School   @relation(fields: [schoolId], references: [id])
  name     String
  nip      String?
  email    String
  phone    String?
  subjects String[]
  isActive Boolean  @default(true)
  createdAt DateTime @default(now())

  homeroomClasses   SchoolClass[]
  teacherAttendances TeacherAttendance[]
  trainingEnrollments TrainingEnrollment[]
  internshipMentoring InternshipPlacement[] @relation("InternshipMentor")

  @@unique([email, schoolId])
}

model SchoolClass {
  id                String   @id @default(cuid())
  schoolId          String
  school            School   @relation(fields: [schoolId], references: [id])
  name              String
  gradeLevel        String
  academicYearId    String
  academicYear      AcademicYear @relation(fields: [academicYearId], references: [id])
  homeroomTeacherId String?
  homeroomTeacher   Teacher? @relation(fields: [homeroomTeacherId], references: [id])
  capacity          Int      @default(36)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())

  enrollments Enrollment[]
  exams       Exam[]
  reportCards ReportCard[]

  @@unique([schoolId, name, academicYearId])
}

model Student {
  id         String   @id @default(cuid())
  schoolId   String
  school     School   @relation(fields: [schoolId], references: [id])
  nisn       String   @unique
  nik        String?
  name       String
  photoUrl   String?
  birthDate  DateTime
  birthPlace String?
  gender     Gender
  religion   String?
  address    String?
  phone      String?
  riskScore     Float    @default(0)
  userId        String?  @unique
  riskUpdatedAt DateTime?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  guardians          Guardian[]
  enrollments        Enrollment[]
  savingsAccount     SavingsAccount?
  studentCard        StudentCard?
  examResults        ExamResult[]
  healthRecord       HealthRecord?
  uksVisits          UKSVisit[]
  nutritionRecords   NutritionRecord[]
  counselingSessions CounselingSession[]
  portfolio          Portfolio?
  alumniProfile      AlumniProfile?
  internships        InternshipPlacement[]
  riskAlerts         RiskAlert[]
  grades             Grade[]
  invoices           Invoice[]
  extraEnrollments   ExtraEnrollment[]
  studentAttendances StudentAttendance[]
  cashlessWallet     CashlessWallet?
  scholarshipApps    ScholarshipApplication[]
  libraryLoans       LibraryLoan[]
  transportLogs      TransportRideLog[]
  menuOrders         MenuOrder[]
  aiInteractions     AIInteraction[]
  plagiarismChecks   PlagiarismCheck[]
  reportCards        ReportCard[]
  specialNeeds       SpecialNeedsProfile?
  pointsAccount      StudentPoints?
}

model Guardian {
  id           String   @id @default(cuid())
  studentId    String
  student      Student  @relation(fields: [studentId], references: [id])
  name         String
  relationship String
  phone        String
  email        String?
  occupation   String?
  address      String?
  createdAt    DateTime @default(now())
}

model Enrollment {
  id             String          @id @default(cuid())
  studentId      String
  student        Student         @relation(fields: [studentId], references: [id])
  classId        String
  schoolClass    SchoolClass     @relation(fields: [classId], references: [id])
  academicYearId String
  academicYear   AcademicYear    @relation(fields: [academicYearId], references: [id])
  schoolId       String
  school         School          @relation(fields: [schoolId], references: [id])
  semesterId     String?
  status         EnrollmentStatus @default(ACTIVE)
  enrolledAt     DateTime        @default(now())

  @@unique([studentId, academicYearId])
}

model StudentAttendance {
  id         String   @id @default(cuid())
  studentId  String
  student    Student  @relation(fields: [studentId], references: [id])
  schoolId   String
  school     School   @relation(fields: [schoolId], references: [id])
  date       DateTime
  status     String
  method     String?
  note       String?
  createdAt  DateTime @default(now())

  @@unique([studentId, date])
}

model TeacherAttendance {
  id        String   @id @default(cuid())
  teacherId String
  teacher   Teacher  @relation(fields: [teacherId], references: [id])
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id])
  date      DateTime
  status    String
  checkIn   String?
  checkOut  String?
  note      String?
  createdAt DateTime @default(now())

  @@unique([teacherId, date])
}

model Schedule {
  id             String   @id @default(cuid())
  schoolId       String
  classId        String
  subjectId      String
  teacherId      String?
  academicYearId String?
  dayOfWeek      Int
  startTime      String
  endTime        String
  room           String?
  createdAt      DateTime @default(now())
}

model Grade {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id])
  subjectId   String
  subject     Subject  @relation(fields: [subjectId], references: [id])
  semesterId  String
  semester    Semester @relation(fields: [semesterId], references: [id])
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id])
  score       Float
  maxScore    Float    @default(100)
  type        String
  description String?
  teacherId   String?
  createdAt   DateTime @default(now())

  @@unique([studentId, subjectId, semesterId, type])
}

model ReportCard {
  id           String   @id @default(cuid())
  studentId    String
  student      Student  @relation(fields: [studentId], references: [id])
  semesterId   String
  semester     Semester @relation(fields: [semesterId], references: [id])
  classId      String?
  schoolClass  SchoolClass? @relation(fields: [classId], references: [id])
  schoolId     String
  school       School   @relation(fields: [schoolId], references: [id])
  averageScore Float    @default(0)
  status       String   @default("DRAFT")
  notes        String?
  createdAt    DateTime @default(now())

  @@unique([studentId, semesterId])
}

// ===================== M02 STUDENT CARD =====================

model StudentCard {
  id         String   @id @default(cuid())
  studentId  String   @unique
  student    Student  @relation(fields: [studentId], references: [id])
  qrCode     String
  validFrom  DateTime
  validUntil DateTime
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
}

// ===================== M03 COOPERATIVE =====================

model SavingsAccount {
  id            String   @id @default(cuid())
  studentId     String   @unique
  student       Student  @relation(fields: [studentId], references: [id])
  schoolId      String
  school        School   @relation(fields: [schoolId], references: [id])
  balance       Float    @default(0)
  accountNumber String   @unique
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  transactions SavingsTransaction[]
}

model SavingsTransaction {
  id           String         @id @default(cuid())
  accountId    String
  account      SavingsAccount @relation(fields: [accountId], references: [id])
  schoolId     String
  school       School         @relation(fields: [schoolId], references: [id])
  type         String
  amount       Float
  balanceAfter Float
  note         String?
  cashierId    String?
  createdAt    DateTime       @default(now())
}

model CoopProduct {
  id        String   @id @default(cuid())
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id])
  name      String
  price     Float
  stock     Int      @default(0)
  category  String?
  imageUrl  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ===================== M05 EXAMS =====================

model Exam {
  id         String     @id @default(cuid())
  schoolId   String
  school     School     @relation(fields: [schoolId], references: [id])
  title      String
  subject    String
  classId    String?
  schoolClass SchoolClass? @relation(fields: [classId], references: [id])
  semesterId String?
  semester   Semester?  @relation(fields: [semesterId], references: [id])
  startTime  DateTime?
  endTime    DateTime?
  timeLimit  Int        @default(90)
  createdBy  String
  status     ExamStatus @default(DRAFT)
  createdAt  DateTime   @default(now())

  questions ExamQuestionMap[]
  results   ExamResult[]
}

model ExamQuestion {
  id          String       @id @default(cuid())
  schoolId    String
  subject     String
  topic       String
  gradeLevel  String
  bloomLevel  BloomLevel
  difficulty  Difficulty
  type        QuestionType
  question    String
  options     Json?
  answer      String
  explanation String?
  generatedBy String       @default("ai")
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())

  exams ExamQuestionMap[]
}

model ExamQuestionMap {
  id         String       @id @default(cuid())
  examId     String
  exam       Exam         @relation(fields: [examId], references: [id])
  questionId String
  question   ExamQuestion @relation(fields: [questionId], references: [id])
  order      Int          @default(0)
}

model ExamResult {
  id             String   @id @default(cuid())
  examId         String
  exam           Exam     @relation(fields: [examId], references: [id])
  studentId      String
  student        Student  @relation(fields: [studentId], references: [id])
  schoolId       String
  answers        Json     @default("{}")
  objectiveScore Float    @default(0)
  essayScore     Float?
  totalScore     Float    @default(0)
  status         String   @default("SUBMITTED")
  submittedAt    DateTime @default(now())

  @@unique([examId, studentId])
}

// ===================== M06 EXTRACURRICULAR =====================

model Extracurricular {
  id           String   @id @default(cuid())
  schoolId     String
  school       School   @relation(fields: [schoolId], references: [id])
  name         String
  description  String?
  supervisorId String?
  schedule     String?
  maxMembers   Int?
  category     String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  enrollments ExtraEnrollment[]
  activities  ExtraActivity[]
}

model ExtraEnrollment {
  id             String         @id @default(cuid())
  studentId      String
  student        Student        @relation(fields: [studentId], references: [id])
  extraId        String
  extracurricular Extracurricular @relation(fields: [extraId], references: [id])
  academicYearId String
  schoolId       String
  school         School         @relation(fields: [schoolId], references: [id])
  status         String         @default("ACTIVE")
  score          Float?
  enrolledAt     DateTime       @default(now())

  @@unique([studentId, extraId, academicYearId])
}

model ExtraActivity {
  id          String         @id @default(cuid())
  extraId     String
  extra       Extracurricular @relation(fields: [extraId], references: [id])
  schoolId    String
  school      School         @relation(fields: [schoolId], references: [id])
  date        DateTime
  title       String
  description String?
  location    String?
  createdAt   DateTime       @default(now())

  attendances ExtraAttendance[]
}

model ExtraAttendance {
  id         String       @id @default(cuid())
  activityId String
  activity   ExtraActivity @relation(fields: [activityId], references: [id])
  studentId  String
  schoolId   String
  status     String

  @@unique([activityId, studentId])
}

// ===================== M07 WEBSITE =====================

model Article {
  id          String   @id @default(cuid())
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id])
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  title       String
  slug        String
  content     String
  excerpt     String?
  imageUrl    String?
  type        String   @default("NEWS")
  tags        String[]
  isPublished Boolean  @default(false)
  publishedAt DateTime?
  viewCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([schoolId, slug])
}

model Announcement {
  id             String   @id @default(cuid())
  schoolId       String
  school         School   @relation(fields: [schoolId], references: [id])
  title          String
  content        String
  targetAudience String   @default("ALL")
  createdBy      String
  isActive       Boolean  @default(true)
  expiresAt      DateTime?
  createdAt      DateTime @default(now())
}

model GalleryItem {
  id        String   @id @default(cuid())
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id])
  title     String
  mediaUrl  String
  mediaType String   @default("IMAGE")
  category  String?
  createdAt DateTime @default(now())
}

// ===================== M08 PPDB =====================

model PPDBPeriod {
  id            String       @id @default(cuid())
  schoolId      String
  school        School       @relation(fields: [schoolId], references: [id])
  name          String
  academicYear  String
  startDate     DateTime
  endDate       DateTime
  quota         Int
  requirements  String?
  selectionType String       @default("SCORE")
  isOpen        Boolean      @default(true)
  createdAt     DateTime     @default(now())

  applications PPDBApplication[]
}

model PPDBApplication {
  id                 String     @id @default(cuid())
  periodId           String
  period             PPDBPeriod @relation(fields: [periodId], references: [id])
  registrationNumber String     @unique
  applicantName      String
  birthDate          DateTime
  gender             String
  parentName         String
  parentPhone        String
  email              String?
  address            String
  previousSchool     String?
  documents          Json       @default("{}")
  status             PPDBStatus @default(SUBMITTED)
  verificationNotes  String?
  createdAt          DateTime   @default(now())
}

// ===================== M13-17 COMMUNICATION =====================

model Notification {
  id          String              @id @default(cuid())
  schoolId    String
  school      School              @relation(fields: [schoolId], references: [id])
  recipientId String
  type        NotificationType
  channel     NotificationChannel
  title       String
  body        String
  status      NotificationStatus  @default(PENDING)
  sentAt      DateTime?
  createdAt   DateTime            @default(now())
}

model NotificationTemplate {
  id            String   @id @default(cuid())
  schoolId      String
  school        School   @relation(fields: [schoolId], references: [id])
  name          String
  type          String
  channel       String
  titleTemplate String
  bodyTemplate  String
  createdAt     DateTime @default(now())

  @@unique([schoolId, name])
}

model ForumPost {
  id          String   @id @default(cuid())
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id])
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  title       String
  content     String
  category    String
  tags        String[]
  isPublished Boolean  @default(true)
  viewCount   Int      @default(0)
  createdAt   DateTime @default(now())

  comments ForumComment[]
}

model ForumComment {
  id        String    @id @default(cuid())
  postId    String
  post      ForumPost @relation(fields: [postId], references: [id])
  authorId  String
  author    User      @relation(fields: [authorId], references: [id])
  content   String
  schoolId  String
  createdAt DateTime  @default(now())
}

model Meeting {
  id           String   @id @default(cuid())
  schoolId     String
  school       School   @relation(fields: [schoolId], references: [id])
  organizerId  String
  organizer    User     @relation("MeetingOrganizer", fields: [organizerId], references: [id])
  title        String
  description  String?
  type         String
  scheduledAt  DateTime
  duration     Int      @default(60)
  location     String?
  meetingUrl   String?
  status       String   @default("SCHEDULED")
  notes        String?
  recordingUrl String?
  createdAt    DateTime @default(now())

  participants MeetingParticipant[]
}

model MeetingParticipant {
  id        String  @id @default(cuid())
  meetingId String
  meeting   Meeting @relation(fields: [meetingId], references: [id])
  userId    String
  user      User    @relation(fields: [userId], references: [id])

  @@unique([meetingId, userId])
}

model BlogPost {
  id          String        @id @default(cuid())
  schoolId    String
  school      School        @relation(fields: [schoolId], references: [id])
  authorId    String
  author      User          @relation(fields: [authorId], references: [id])
  title       String
  content     String
  category    String?
  status      BlogPostStatus @default(DRAFT)
  isPublished Boolean       @default(false)
  publishedAt DateTime?
  createdAt   DateTime      @default(now())
}

// ===================== M18-22 FINANCE =====================

model Invoice {
  id            String        @id @default(cuid())
  schoolId      String
  school        School        @relation(fields: [schoolId], references: [id])
  studentId     String
  student       Student       @relation(fields: [studentId], references: [id])
  invoiceNumber String        @unique
  type          String        @default("SPP")
  amount        Float
  dueDate       DateTime
  semesterId    String?
  semester      Semester?     @relation(fields: [semesterId], references: [id])
  status        InvoiceStatus @default(UNPAID)
  paidAt        DateTime?
  createdAt     DateTime      @default(now())

  payments Payment[]
}

model Payment {
  id            String        @id @default(cuid())
  invoiceId     String
