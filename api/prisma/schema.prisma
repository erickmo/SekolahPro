  id             String              @id @default(cuid())
  budgetPlanId   String
  budgetPlan     BudgetPlan          @relation(fields: [budgetPlanId], references: [id])
  schoolId       String
  category       String
  description    String
  plannedAmount  Decimal
  realizedAmount Decimal             @default(0)
  realizations   BudgetRealization[]
  createdAt      DateTime            @default(now())
}

model BudgetRealization {
  id              String     @id @default(cuid())
  lineId          String
  line            BudgetLine @relation(fields: [lineId], references: [id])
  schoolId        String
  amount          Decimal
  date            DateTime
  description     String
  receiptUrl      String?
  recordedBy      String
  vernonJournalId String?
  createdAt       DateTime   @default(now())
}

// ===================== M52 — DANA KOMITE =====================

model DonationRecord {
  id              String   @id @default(cuid())
  schoolId        String
  donorId         String?
  donorName       String
  amount          Decimal
  purpose         String
  eventId         String?
  isAnonymous     Boolean  @default(false)
  receiptUrl      String?
  vernonJournalId String?
  createdAt       DateTime @default(now())
}

// ===================== M53 — KOMITE SEKOLAH DIGITAL =====================

model CommitteeBoard {
  id          String             @id @default(cuid())
  schoolId    String
  periodStart DateTime
  periodEnd   DateTime
  members     CommitteeMember[]
  meetings    CommitteeMeeting[]
  createdAt   DateTime           @default(now())
}

model CommitteeMember {
  id        String         @id @default(cuid())
  boardId   String
  board     CommitteeBoard @relation(fields: [boardId], references: [id])
  userId    String?
  name      String
  role      String
  phone     String?
  createdAt DateTime       @default(now())
}

model CommitteeMeeting {
  id           String              @id @default(cuid())
  boardId      String
  board        CommitteeBoard      @relation(fields: [boardId], references: [id])
  schoolId     String
  scheduledAt  DateTime
  agenda       String[]
  videoCallUrl String?
  minutesUrl   String?
  status       String              @default("SCHEDULED")
  decisions    CommitteeDecision[]
  createdAt    DateTime            @default(now())
}

model CommitteeDecision {
  id          String           @id @default(cuid())
  meetingId   String
  meeting     CommitteeMeeting @relation(fields: [meetingId], references: [id])
  boardId     String
  title       String
  description String
  votesFor    Int              @default(0)
  votesAgainst Int             @default(0)
  votesAbstain Int             @default(0)
  result      String
  signedByIds String[]
  signedAt    DateTime?
  isBinding   Boolean          @default(false)
  createdAt   DateTime         @default(now())
}

// ===================== M54 — VOLUNTEER & KOMUNITAS =====================

model VolunteerProfile {
  id           String                 @id @default(cuid())
  schoolId     String
  name         String
  email        String?
  phone        String?
  relation     VolunteerRelation
  skills       String[]
  availability Json?
  totalHours   Float                  @default(0)
  activities   VolunteerActivity[]
  certificates VolunteerCertificate[]
  createdAt    DateTime               @default(now())
}

model VolunteerActivity {
  id          String           @id @default(cuid())
  volunteerId String
  volunteer   VolunteerProfile @relation(fields: [volunteerId], references: [id])
  schoolId    String
  title       String
  date        DateTime
  hours       Float
  notes       String?
  createdAt   DateTime         @default(now())
}

model VolunteerCertificate {
  id          String           @id @default(cuid())
  volunteerId String
  volunteer   VolunteerProfile @relation(fields: [volunteerId], references: [id])
  schoolId    String
  title       String
  issuedAt    DateTime
  pdfUrl      String?
  createdAt   DateTime         @default(now())
}

// ===================== M55 — MANAJEMEN ABK =====================

model SpecialNeedsProfile {
  id                  String              @id @default(cuid())
  studentId           String              @unique
  student             Student             @relation(fields: [studentId], references: [id])
  schoolId            String
  encryptedData       String
  requiresExtraTime   Boolean             @default(false)
  requiresAssistant   Boolean             @default(false)
  requiresLargeFont   Boolean             @default(false)
  gpkId               String?
  ieps                IEP[]
  progressReports     ABKProgressReport[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
}

model IEP {
  id           String              @id @default(cuid())
  profileId    String
  profile      SpecialNeedsProfile @relation(fields: [profileId], references: [id])
  schoolId     String
  academicYear String
  semester     Int
  goals        Json
  gpkId        String
  approvedBy   String?
  approvedAt   DateTime?
  createdAt    DateTime            @default(now())
}

model ABKProgressReport {
  id        String              @id @default(cuid())
  profileId String
  profile   SpecialNeedsProfile @relation(fields: [profileId], references: [id])
  schoolId  String
  period    String
  content   Json
  gpkId     String
  createdAt DateTime            @default(now())
}

// ===================== M56 — SERAGAM & ATRIBUT =====================

model UniformItem {
  id          String         @id @default(cuid())
  schoolId    String
  name        String
  description String?
  price       Decimal
  sizes       String[]
  imageUrl    String?
  stock       Json
  vendorId    String?
  isActive    Boolean        @default(true)
  orders      UniformOrder[]
  createdAt   DateTime       @default(now())
}

model UniformOrder {
  id          String      @id @default(cuid())
  schoolId    String
  itemId      String
  item        UniformItem @relation(fields: [itemId], references: [id])
  studentId   String
  size        String
  quantity    Int
  totalPrice  Decimal
  status      String      @default("PENDING")
  paidAt      DateTime?
  deliveredAt DateTime?
  createdAt   DateTime    @default(now())
}

// ===================== M57 — EVENT & KEPANITIAAN =====================

model SchoolEvent {
  id          String           @id @default(cuid())
  schoolId    String
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime
  location    String?
  type        String
  status      String           @default("PLANNING")
  tasks       EventTask[]
  budgets     EventBudget[]
  committees  EventCommittee[]
  createdAt   DateTime         @default(now())
}

model EventTask {
  id         String      @id @default(cuid())
  eventId    String
  event      SchoolEvent @relation(fields: [eventId], references: [id])
  title      String
  assigneeId String?
  dueDate    DateTime?
  status     String      @default("TODO")
  createdAt  DateTime    @default(now())
}

model EventBudget {
  id       String      @id @default(cuid())
  eventId  String
  event    SchoolEvent @relation(fields: [eventId], references: [id])
  category String
  planned  Decimal
  actual   Decimal     @default(0)
  notes    String?
  createdAt DateTime   @default(now())
}

model EventCommittee {
  id        String      @id @default(cuid())
  eventId   String
  event     SchoolEvent @relation(fields: [eventId], references: [id])
  userId    String
  role      String
  createdAt DateTime    @default(now())
}

// ===================== M59 — IOT & SMART CAMPUS =====================

model IoTDevice {
  id        String        @id @default(cuid())
  schoolId  String
  name      String
  type      IoTDeviceType
  location  String
  mqttTopic String        @unique
  isActive  Boolean       @default(true)
  lastPing  DateTime?
  metadata  Json?
  readings  IoTReading[]
  createdAt DateTime      @default(now())
}

model IoTReading {
  id         String    @id @default(cuid())
  deviceId   String
  device     IoTDevice @relation(fields: [deviceId], references: [id])
  value      Float
  unit       String
  metadata   Json?
  recordedAt DateTime  @default(now())

  @@index([deviceId, recordedAt])
}

// ===================== M60 — GAMIFIKASI & LOYALITAS =====================

model PointRule {
  id          String        @id @default(cuid())
  schoolId    String
  type        PointRuleType
  points      Int
  description String
  conditions  Json?
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
}

model StudentPoints {
  id           String             @id @default(cuid())
  studentId    String             @unique
  student      Student            @relation(fields: [studentId], references: [id])
  schoolId     String
  totalPoints  Int                @default(0)
  streak       Int                @default(0)
  lastActivity DateTime?
  transactions PointTransaction[]
  badges       StudentBadge[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

model PointTransaction {
  id        String        @id @default(cuid())
  accountId String
  account   StudentPoints @relation(fields: [accountId], references: [id])
  schoolId  String
  type      String
  points    Int
  reason    String
  ruleId    String?
  createdAt DateTime      @default(now())
}

model Badge {
  id            String         @id @default(cuid())
  schoolId      String
  name          String
  description   String
  iconUrl       String?
  criteria      Json
  createdAt     DateTime       @default(now())
  studentBadges StudentBadge[]
}

model StudentBadge {
  id        String        @id @default(cuid())
  studentId String
  account   StudentPoints @relation(fields: [accountId], references: [id])
  accountId String
  badgeId   String
  badge     Badge         @relation(fields: [badgeId], references: [id])
  awardedAt DateTime      @default(now())

  @@unique([accountId, badgeId])
}

// ===================== M61 — MARKETPLACE KONTEN EDUKATIF =====================

model EduContent {
  id             String           @id @default(cuid())
  schoolOrigin   String
  authorId       String
  title          String
  description    String
  type           EduContentType
  price          Decimal          @default(0)
  licenseType    String           @default("SINGLE_SCHOOL")
  fileUrl        String?
  previewUrl     String?
  status         EduContentStatus @default(PENDING_REVIEW)
  aiQualityScore Float?
  downloads      Int              @default(0)
  rating         Float            @default(0)
  reviewCount    Int              @default(0)
  purchases      ContentPurchase[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model ContentPurchase {
  id          String     @id @default(cuid())
  contentId   String
  content     EduContent @relation(fields: [contentId], references: [id])
  schoolId    String
  buyerId     String
  amount      Decimal
  royaltyPaid Decimal
  paymentId   String?
  createdAt   DateTime   @default(now())

  @@unique([contentId, schoolId])
}

// ===================== AI USAGE TRACKING =====================

model AIUsageLog {
  id           String   @id @default(cuid())
  schoolId     String
  userId       String
  moduleId     String
  model        String
  inputTokens  Int
  outputTokens Int
  cost         Decimal?
  createdAt    DateTime @default(now())

  @@index([schoolId, moduleId, createdAt])
}
